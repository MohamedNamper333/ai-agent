# ─────────────────────────────────────────────────────────────
#  AI Agent — Environment Variables
#  Copy to .env and fill in your values:
#      cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Security (CHANGE THESE IN PRODUCTION) ─────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
API_KEY_HASH_SALT=change-me-to-another-random-string

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated allowed origins. Use * only for development.
CORS_ORIGINS=http://localhost:8080

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── LLM Backend ───────────────────────────────────────────────
# Options: auto | ollama | gpt4all | llama
BACKEND=ollama
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE=http://127.0.0.1:11434

# ── OpenCode Zen (free cloud models) ──────────────────────────
OPENCODE_ZEN_KEY=your-opencode-zen-key-here
OPENCODE_ZEN_URL=https://opencode.ai/zen/v1

# ── OpenAI (GPT-4, paid) ──────────────────────────────────────
# OPENAI_API_KEY=sk-your-key-here

# ── Anthropic (Claude API, paid) ──────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── LLM Routing ───────────────────────────────────────────────
LLM_SIMPLE_MODEL=qwen2.5:7b
LLM_MODERATE_MODEL=deepseek-v4-flash-free
LLM_DEEP_MODEL=big-pickle
LLM_AUTO_ROUTE=true
LLM_DEFAULT_LEVEL=simple
LLM_REQUEST_TIMEOUT=120
LLM_MAX_RETRIES=2

# ── Web Server ────────────────────────────────────────────────
WEB_HOST=127.0.0.1
WEB_PORT=8080

# ── Production Server ─────────────────────────────────────────
GUNICORN_WORKERS=4
GUNICORN_THREADS=1
GUNICORN_TIMEOUT=300

# ── Database ──────────────────────────────────────────────────
DB_PATH=memory_store.json
# DATABASE_URL=postgresql://user:password@localhost/aiagent  # Phase 1

# ── Cache ─────────────────────────────────────────────────────
CACHE_TTL=300
# REDIS_URL=redis://localhost:6379/0  # Phase 4

# ── RAG ───────────────────────────────────────────────────────
RAG_ENABLED=true

# ── Performance ───────────────────────────────────────────────
FAST_MODE=auto
